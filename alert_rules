#Average CPU usage - advanced sql query
SELECT devices.device_id,AVG(processors.processor_usage) as cpu_avg FROM devices,processors WHERE (devices.device_id= ? AND devices.device_id = processors.device_id) AND (devices.status = 1 && (devices.disabled = 0 && devices.ignore = 0)) = 1 GROUP BY processors.processor_usage,devices.device_id HAVING processors.processor_usage > 90;

#SMART application SSD wear
SELECT * FROM devices,applications,application_metrics WHERE (devices.device_id = ? AND devices.device_id = applications.device_id AND applications.app_id = application_metrics.app_id) AND application_metrics.value <= 20 AND application_metrics.metric LIKE '%_id231'
